DirectoryIndex index.html

RewriteEngine On

# Serve static assets (images, sw.js, manifest, css, js) directly — skip Node.js
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} \.(png|jpg|jpeg|gif|ico|svg|webp|css|js|json|txt|woff|woff2|ttf)$ [NC]
RewriteRule ^ - [L]

# All other requests (including / and /api/*) go through Node.js via Passenger
