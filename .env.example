# Copy this file to .env and fill in your values
PORT=3000
PREVIEW_TOKEN=your_secret_token_here

# Admin reset password — set a strong password, never share or commit this
ADMIN_RESET_PASSWORD=change_this_to_a_strong_password

# MySQL / Hostinger database credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_username
DB_PASS=your_db_password
DB_NAME=your_db_name
