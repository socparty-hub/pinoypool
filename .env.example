# ─────────────────────────────────────────────
#  PinoyPool — Environment Variables
#  Copy this to .env on your server and fill in values
#  DO NOT commit .env to GitHub
# ─────────────────────────────────────────────

# Server
PORT=3000

# Set to true to show Coming Soon page instead of full app
# Leave empty or false to show the full app
COMING_SOON=false

# Email notifications (Gmail App Password)
# Get App Password: Google Account → Security → 2-Step → App Passwords
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
NOTIFY_TO=yourname@gmail.com
